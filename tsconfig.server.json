{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./dist-api",
    "rootDir": "./",
    "strict": false,
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": ["api/**/*", "middleware/**/*", "db.ts"],
  "exclude": ["node_modules", "dist"]
}
