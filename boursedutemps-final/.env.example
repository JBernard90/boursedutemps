# ============================================================
# VARIABLES D'ENVIRONNEMENT — Bourse du Temps
# Copiez ce fichier en .env.local pour le développement local
# Sur Vercel : Settings → Environment Variables
# ============================================================

# Base de données Neon PostgreSQL (OBLIGATOIRE)
# Récupérez-la sur : https://neon.tech → votre projet → Connection Details
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# JWT Secret (OBLIGATOIRE) — chaîne aléatoire longue d'au moins 32 caractères
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire_minimum_32_chars

# Email Gmail pour Nodemailer (optionnel mais recommandé)
# Créez un mot de passe d'application sur : https://myaccount.google.com/apppasswords
EMAIL_USER=votre@gmail.com
EMAIL_PASS=votre_mot_de_passe_application_16_caracteres

# TextBee SMS (optionnel)
TEXTBEE_API_KEY=votre_api_key_textbee
TEXTBEE_SENDER_ID=votre_device_id_textbee
